# ── DUT Project Hub – Environment Variables ─────────────────────────────────
# Copy this to .env and fill in your values

SECRET_KEY=change-me-to-a-long-random-string-in-production

# Database (SQLite default; use postgresql+psycopg2://... for PostgreSQL)
DATABASE_URL=sqlite:///hub.db

# ── Flask-Mail (Office 365 SMTP) ─────────────────────────────────────────────
MAIL_SERVER=smtp.office365.com
MAIL_PORT=587
MAIL_USERNAME=noreply@dut.ac.za
MAIL_PASSWORD=your-email-password
MAIL_DEFAULT_SENDER=noreply@dut.ac.za

# ── Microsoft Azure AD OAuth ─────────────────────────────────────────────────
# Register an app at https://portal.azure.com → Azure Active Directory → App Registrations
# Redirect URI: http://localhost:5000/auth/microsoft/callback
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-app-client-secret
# Use your DUT tenant ID for institutional SSO, or 'common' for any Microsoft account
MICROSOFT_TENANT_ID=your-dut-tenant-id
